<?xml version="1.0" encoding="utf-8" ?>
<component name="AddSourceScene" extends="Scene">

  <script type="text/brightscript" uri="pkg:/components/AddSourceScene.brs" />

  <interface>

    <field id="result"  type="assocarray" />

    <field id="closed"  type="boolean"    value="false" />
  </interface>

  <children>

    <!-- dim overlay -->
    <Rectangle
        id="dimBg"
        translation="[0,0]"
        width="1920"
        height="1080"
        color="0x000000DD" />

    <!-- dialog box -->
    <Rectangle
        id="dialogBox"
        translation="[360,120]"
        width="1200"
        height="840"
        color="0x0D1428FF" />

    <!-- accent line -->
    <Rectangle
        translation="[360,120]"
        width="6"
        height="840"
        color="0x4A9FFFFF" />

    <Label
        id="dlgTitle"
        translation="[400,140]"
        width="1120"
        font="font:LargeBoldSystemFont"
        color="0x4A9FFFFF"
        text="Add Source" />

    <!-- TAB bar -->
    <Rectangle
        translation="[360,200]"
        width="1200"
        height="2"
        color="0x1A3A6AFF" />

    <Label
        id="tabM3U"
        translation="[400,210]"
        width="200"
        font="font:MediumBoldSystemFont"
        color="0xFFFFFFFF"
        text="M3U / URL" />

    <Label
        id="tabXtream"
        translation="[640,210]"
        width="240"
        font="font:MediumBoldSystemFont"
        color="0x556688FF"
        text="Xtream Codes" />

    <!-- tab underline -->
    <Rectangle
        id="tabUnderline"
        translation="[400,238]"
        width="200"
        height="3"
        color="0x4A9FFFFF" />

    <Rectangle
        translation="[360,244]"
        width="1200"
        height="2"
        color="0x1A3A6AFF" />

    <!-- ===== M3U panel ===== -->
    <Group id="panelM3U" translation="[0,0]" visible="true">

      <Label
          translation="[400,270]"
          font="font:SmallSystemFont"
          color="0xAABBCCFF"
          text="Playlist URL  (.m3u / .m3u8 / direct stream)" />

      <Rectangle
          id="urlBox"
          translation="[390,300]"
          width="1100"
          height="54"
          color="0x141E38FF" />

      <TextEditBox
          id="urlInput"
          translation="[400,308]"
          width="1080"
          height="40"
          focusable="true"
          maxTextLength="512" />

      <Label
          id="m3uHint"
          translation="[400,368]"
          width="1100"
          font="font:SmallSystemFont"
          color="0x556688FF"
          text="e.g.  http://myserver.com/playlist.m3u?username=u&amp;password=p" />

    </Group>

    <!-- ===== Xtream panel ===== -->
    <Group id="panelXtream" translation="[0,0]" visible="false">

      <Label
          translation="[400,270]"
          font="font:SmallSystemFont"
          color="0xAABBCCFF"
          text="Server URL" />

      <Rectangle
          translation="[390,298]"
          width="1100"
          height="50"
          color="0x141E38FF" />

      <TextEditBox
          id="xtHost"
          translation="[400,304]"
          width="1080"
          height="38"
          focusable="true"
          maxTextLength="256" />

      <Label
          translation="[400,360]"
          font="font:SmallSystemFont"
          color="0xAABBCCFF"
          text="Username" />

      <Rectangle
          translation="[390,386]"
          width="530"
          height="50"
          color="0x141E38FF" />

      <TextEditBox
          id="xtUser"
          translation="[400,392]"
          width="520"
          height="38"
          focusable="true"
          maxTextLength="128" />

      <Label
          translation="[960,360]"
          font="font:SmallSystemFont"
          color="0xAABBCCFF"
          text="Password" />

      <Rectangle
          translation="[950,386]"
          width="530"
          height="50"
          color="0x141E38FF" />

      <TextEditBox
          id="xtPass"
          translation="[960,392]"
          width="520"
          height="38"
          focusable="true"
          maxTextLength="128" />

      <Label
          id="xtHint"
          translation="[400,448]"
          width="1100"
          font="font:SmallSystemFont"
          color="0x556688FF"
          text="e.g.  http://myserver.com:8080   (no trailing slash)" />

    </Group>

    <!-- ===== Saved sources list ===== -->
    <Rectangle
        translation="[360,520]"
        width="1200"
        height="2"
        color="0x1A3A6AFF" />

    <Label
        translation="[400,530]"
        font="font:SmallBoldSystemFont"
        color="0x7AAFEFFF"
        text="Saved Sources" />

    <LabelList
        id="savedList"
        translation="[390,560]"
        itemSize="[1100,44]"
        numRows="5"
        drawFocusFeedback="true"
        focusBitmapUri=""
        visible="true" />

    <!-- ===== Buttons ===== -->
    <Rectangle
        translation="[360,930]"
        width="1200"
        height="2"
        color="0x1A3A6AFF" />

    <Label
        id="btnSave"
        translation="[400,944]"
        width="200"
        font="font:MediumBoldSystemFont"
        color="0x4A9FFFFF"
        text="[ Save ]" />

    <Label
        id="btnDelete"
        translation="[640,944]"
        width="240"
        font="font:MediumBoldSystemFont"
        color="0xFF6666FF"
        text="[ Delete ]" />

    <Label
        id="btnCancel"
        translation="[1380,944]"
        width="160"
        font="font:MediumBoldSystemFont"
        color="0x888888FF"
        text="[ Cancel ]" />

    <Label
        id="msgLabel"
        translation="[900,944]"
        width="460"
        font="font:SmallSystemFont"
        color="0xFF9933FF"
        text="" />

  </children>

</component>
