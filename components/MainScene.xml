<?xml version="1.0" encoding="utf-8" ?>
<component name="MainScene" extends="Scene">
  <script type="text/brightscript" uri="pkg:/components/MainScene.brs" />
  <children>

    <!-- full dark background -->
    <Rectangle width="1920" height="1080" color="0x090C18FF" />

    <!-- ===== TOP BAR ===== -->
    <Rectangle width="1920" height="70" color="0x060810FF" />
    <Rectangle translation="[0,70]" width="1920" height="2" color="0x1E4080FF" />

    <Label id="appTitle" translation="[30,15]"
        font="font:LargeBoldSystemFont" color="0x3A8FFFFF" text="IRAN IPTV" />

    <Label id="statusLabel" translation="[280,22]" width="1200"
        font="font:SmallSystemFont" color="0x3A6A9AFF" text="" />

    <Label id="clockLabel" translation="[1750,20]" width="148"
        font="font:SmallBoldSystemFont" color="0x3A8FFFFF"
        horizAlign="right" text="" />

    <!-- now playing mini -->
    <Rectangle id="nowPlayingBar" translation="[1360,0]" width="560" height="70"
        color="0x0C1C3CCC" visible="false" />
    <Label id="nowPlayingTitle" translation="[1376,10]" width="530"
        font="font:SmallBoldSystemFont" color="0xFFFFFFFF" text="" visible="false" />
    <Label id="nowPlayingStatus" translation="[1376,40]"
        font="font:SmallSystemFont" color="0xFF3333FF" text="LIVE" visible="false" />

    <!-- ===== LEFT: CATEGORIES ===== -->
    <Rectangle translation="[0,72]" width="320" height="938" color="0x060810FF" />
    <Rectangle translation="[320,72]" width="2" height="938" color="0x1E4080FF" />

    <Label translation="[14,82]" font="font:SmallBoldSystemFont"
        color="0x285080FF" text="CATEGORIES" />

    <LabelList id="groupList" translation="[4,110]"
        itemSize="[312,46]" numRows="19"
        drawFocusFeedback="true" focusBitmapUri="" visible="false" />

    <!-- ===== MIDDLE: CHANNELS ===== -->
    <Rectangle translation="[322,72]" width="808" height="938" color="0x050810FF" />
    <Rectangle translation="[1130,72]" width="2" height="938" color="0x1E4080FF" />

    <Label id="channelHeader" translation="[340,82]" width="630"
        font="font:SmallBoldSystemFont" color="0x6AABEFFF" text="" />
    <Label id="channelCount" translation="[340,82]" width="778"
        font="font:SmallSystemFont" color="0x285080FF"
        horizAlign="right" text="" />

    <MarkupList id="channelList" translation="[328,110]"
        itemComponentName="ChannelItem"
        itemSize="[796,72]" numRows="12"
        drawFocusFeedback="true" focusBitmapUri="" visible="false" />

    <!-- ===== RIGHT: DETAIL ===== -->
    <Rectangle translation="[1130,72]" width="790" height="938" color="0x04060EFF" />

    <!-- logo box -->
    <Rectangle id="bigLogoBox" translation="[1162,96]"
        width="726" height="198" color="0x0C1428FF" />
    <Poster id="bigLogoImg" translation="[1162,96]"
        width="726" height="198" loadDisplayMode="scaleToFit" uri="" />
    <Label id="bigLogoFallback" translation="[1162,96]"
        width="726" height="198"
        horizAlign="center" vertAlign="center"
        font="font:LargeBoldSystemFont" color="0x182848FF" text="TV" />

    <!-- channel name + group -->
    <Label id="detailTitle" translation="[1162,336]" width="726"
        font="font:LargeBoldSystemFont" color="0xFFFFFFFF" text="" />
    <Label id="detailGroup" translation="[1162,390]" width="726"
        font="font:SmallSystemFont" color="0x3A8FFFFF" text="" />

    <Rectangle translation="[1162,428]" width="726" height="1" color="0x182848FF" />

    <Label translation="[1162,440]"
        font="font:SmallBoldSystemFont" color="0x285080FF" text="NOW ON AIR" />
    <Label id="epgNowTitle" translation="[1162,468]" width="726"
        font="font:SmallBoldSystemFont" color="0xCCDDEEFF" text="Live Stream" />

    <Rectangle translation="[1162,504]" width="726" height="1" color="0x182848FF" />

    <!-- badges -->
    <Rectangle translation="[1162,514]" width="54" height="26" color="0x0C1E3CFF" />
    <Label id="qualityLabel" translation="[1164,516]" width="50" height="22"
        horizAlign="center" font="font:SmallBoldSystemFont"
        color="0x3A8FFFFF" text="HLS" />
    <Label id="liveIndicator" translation="[1228,514]"
        font="font:SmallBoldSystemFont" color="0xFF3333FF" text="LIVE" />

    <!-- Add Source button in detail panel -->
    <Rectangle id="addSrcBtn" translation="[1162,580]"
        width="240" height="44" color="0x0C1E3CFF" focusable="true" />
    <Label id="addSrcBtnLabel" translation="[1164,590]" width="236" height="34"
        horizAlign="center" font="font:SmallBoldSystemFont"
        color="0x4A9FFFFF" text="+ Add Source" />

    <!-- key hints -->
    <Rectangle translation="[1130,938]" width="790" height="70" color="0x060810FF" />
    <Rectangle translation="[1130,938]" width="790" height="1" color="0x1E4080FF" />
    <Label id="keyHint1" translation="[1150,946]" width="750"
        font="font:SmallSystemFont" color="0x25456AFF"
        text="OK: Play   UP/DN: Skip   LEFT/RIGHT: Panel" />
    <Label id="keyHint2" translation="[1150,968]" width="750"
        font="font:SmallSystemFont" color="0x25456AFF"
        text="* : Search   OK on [+Add Source]: Settings   Play: Fav" />

    <!-- ===== SEARCH OVERLAY ===== -->
    <Rectangle id="searchOverlay" width="1920" height="1080"
        color="0x000000F0" visible="false" />
    <Rectangle id="searchBox" translation="[540,280]" width="840" height="58"
        color="0x0C1428FF" visible="false" />
    <Label id="searchTitle" translation="[560,292]"
        font="font:SmallBoldSystemFont" color="0x3A8FFFFF"
        text="SEARCH" visible="false" />
    <MiniKeyboard id="SearchKeyboard" translation="[540,348]"
        visible="false" focusable="true" />

    <!-- ===== VIDEO ===== -->
    <Video id="myVideo" width="1920" height="1080" translation="[0,0]"
        visible="false" enableUI="false" enableTrickPlay="false" />

    <!-- ===== BUFFER OVERLAY ===== -->
    <Rectangle id="bufferOverlay" width="1920" height="1080"
        color="0x000000EC" visible="false" />
    <BusySpinner id="bufferSpinner" translation="[910,430]" visible="false" />
    <Label id="bufferTitle" translation="[0,536]" width="1920"
        horizAlign="center" font="font:LargeBoldSystemFont"
        color="0xFFFFFFFF" text="" visible="false" />
    <Label id="bufferStatus" translation="[0,600]" width="1920"
        horizAlign="center" font="font:SmallSystemFont"
        color="0x3A8FFFFF" text="Connecting..." visible="false" />
    <Label id="retryDots" translation="[0,636]" width="1920"
        horizAlign="center" font="font:SmallSystemFont"
        color="0x285080FF" text="" visible="false" />

    <!-- ===== NOW PLAYING INFO BAR ===== -->
    <Rectangle id="infoOverlay" translation="[0,858]" width="1920" height="222"
        color="0x000000CC" visible="false" />
    <Rectangle id="infoAccentLine" translation="[0,858]" width="1920" height="4"
        color="0x3A8FFFFF" visible="false" />

    <Rectangle id="infoLogoBox" translation="[30,874]"
        width="148" height="148" color="0x0C1428FF" visible="false" />
    <Poster id="infoLogoImg" translation="[30,874]"
        width="148" height="148" loadDisplayMode="scaleToFit"
        uri="" visible="false" />
    <Label id="infoLogoFallback" translation="[30,874]"
        width="148" height="148"
        horizAlign="center" vertAlign="center"
        font="font:LargeBoldSystemFont" color="0x182848FF"
        text="TV" visible="false" />

    <Label id="infoTitle" translation="[194,882]" width="1100"
        font="font:LargeBoldSystemFont" color="0xFFFFFFFF"
        text="" visible="false" />
    <Label id="infoCategory" translation="[194,954]" width="900"
        font="font:SmallSystemFont" color="0x3A8FFFFF"
        text="" visible="false" />

    <Rectangle id="liveBadge" translation="[1614,880]"
        width="98" height="30" color="0xCC1010EE" visible="false" />
    <Label id="liveBadgeText" translation="[1616,882]" width="94" height="26"
        horizAlign="center" font="font:SmallBoldSystemFont"
        color="0xFFFFFFFF" text="LIVE" visible="false" />
    <Label id="skipHint" translation="[1726,882]" width="168"
        font="font:SmallSystemFont" color="0x2A5A8AFF"
        text="UP/DN: Ch" visible="false" />

    <!-- ===== LOADING ===== -->
    <BusySpinner id="spinner" translation="[940,490]" visible="true" />
    <Label id="loadingLabel" translation="[0,558]" width="1920"
        horizAlign="center" font="font:SmallSystemFont"
        color="0x3A8FFFFF" text="Loading playlist..." visible="true" />

    <Timer id="infoTimer"     duration="5"  repeat="false" />
    <Timer id="bufferTimer"   duration="30" repeat="false" />
    <Timer id="watchdogTimer" duration="60" repeat="false" />
    <Timer id="retryTimer"    duration="2"  repeat="false" />
    <Timer id="clockTimer"    duration="1"  repeat="true"  />

  </children>
</component>
