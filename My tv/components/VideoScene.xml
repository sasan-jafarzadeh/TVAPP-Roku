<?xml version="1.0" encoding="utf-8" ?>
<component name="VideoScene" extends="Scene">
  <children>
    <Video id="myVideo" width="1920" height="1080" loadDisplayMode="zoom" />

    <Rectangle id="listBackground" width="600" height="1080" translation="[-600,0]" color="0x121212F2">
        <Label id="menuTitle" text="Categories" translation="[50, 40]" font="font:LargeBoldSystemFont" color="0x00AFFFFF" />
        <LabelList id="categoryList" translation="[20, 120]" itemSize="[560, 60]" />
        <LabelList id="channelList" translation="[20, 120]" itemSize="[560, 80]" visible="false" />
    </Rectangle>

    <Animation id="menuAnim" duration="0.3" easeFunction="outCubic">
        <Vector2DFieldInterpolator id="menuInterp" key="[0, 1]" fieldToInterp="listBackground.translation" />
    </Animation>

    <Rectangle id="infoBar" width="1920" height="300" translation="[0, 780]" color="0x000000CC" visible="false">
        <Poster id="channelLogo" width="180" height="180" translation="[80, 60]" loadDisplayMode="limitSize" />
        <Label id="channelTitle" width="1100" height="60" translation="[300, 70]" font="font:ExtraLargeBoldSystemFont" color="0xFFFFFFFF" />
        <Label id="groupTitle" width="1100" height="40" translation="[300, 150]" font="font:MediumSystemFont" color="0x00AFFFFF" />
        <Rectangle width="20" height="20" translation="[300, 210]" color="0xFF0000FF" />
        <Label text="LIVE" translation="[330, 202]" font="font:SmallBoldSystemFont" color="0xFF0000FF" />
        <Label id="errorMsg" width="800" height="40" translation="[450, 202]" font="font:SmallSystemFont" color="0xFFAA00FF" visible="false" />
    </Rectangle>

    <Rectangle id="splashLayer" width="1920" height="1080" color="0x121212FF" visible="true">
        <Poster id="splashLogo" width="600" height="600" translation="[660, 240]" uri="pkg:/images/logo_big.png" loadDisplayMode="limitSize" />
        <Label text="Version 1.0.0" translation="[860, 950]" font="font:SmallSystemFont" color="0x555555FF" />
        <BusyIndicator id="loadingIndicator" translation="[930, 850]" visible="true" />
    </Rectangle>

    <Animation id="fadeSplash" duration="1.0" easeFunction="linear">
        <FloatFieldInterpolator key="[0, 1]" keyValue="[1.0, 0.0]" fieldToInterp="splashLayer.opacity" />
    </Animation>

    <Label id="clockLabel" translation="[1720, 40]" font="font:MediumBoldSystemFont" color="0xFFFFFF44" />
    <Timer id="uiTimer" repeat="false" />
    <Timer id="clockTimer" repeat="true" duration="30" />
  </children>

  <script type="text/brightscript" uri="pkg:/components/VideoScene.brs" />
</component>